{
  "crawler": {
    "userAgent": "SierraNueva/0.1 (validacion manual de fuente; ejecucion local limitada)",
    "requestDelayMilliseconds": 5000,
    "maxPagesPerSource": 3,
    "maxDepth": 0,
    "timeoutSeconds": 30,
    "maxRetries": 1,
    "maxResponseBytes": 1000000,
    "maxPdfBytes": 15000000,
    "deactivateAfterMisses": 3,
    "publicChangeLimit": 5000,
    "staleAfterHours": 96,
    "enablePlaywright": false,
    "nominatim": {
      "enabled": false,
      "endpoint": "https://nominatim.openstreetmap.org",
      "maxRequestsPerMinute": 4
    },
    "map": {
      "tileUrl": "https://tile.openstreetmap.org/{z}/{x}/{y}.png",
      "attribution": "© OpenStreetMap contributors"
    }
  }
}
