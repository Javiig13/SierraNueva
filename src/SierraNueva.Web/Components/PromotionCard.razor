<article class="promotion-card @(Promotion.Active ? null : "is-inactive") @(IsHighlighted ? "is-highlighted" : null)"
         data-promotion-id="@Promotion.Id"
         @onmouseenter="HighlightAsync"
         @onmouseleave="ClearHighlightAsync"
         @onfocusin="HighlightAsync"
         @onfocusout="ClearHighlightAsync">
    <div class="card-topline">
        <span class="municipality">
            <i aria-hidden="true"></i>
            @Promotion.Municipality
        </span>
        <span class="status status-@Promotion.CommercialStatus.ToString().ToLowerInvariant()">
            @UiFormatting.Commercial(Promotion.CommercialStatus)
        </span>
    </div>

    <div class="card-heading">
        <div class="badge-row" aria-label="Novedades">
            @if (IsNew)
            {
                <span class="badge badge-new">Nueva</span>
            }
            else if (IsChanged)
            {
                <span class="badge badge-changed">Actualizada</span>
            }
            @if (Promotion.LocationPrecision is not LocationPrecision.ExactCoordinates)
            {
                <span class="badge badge-muted">Ubicación aproximada</span>
            }
        </div>
        <h3>
            <button class="card-title-button" type="button" @onclick="OpenAsync">
                @Promotion.Name
            </button>
        </h3>
        <p class="developer">@(Promotion.DeveloperName ?? "Promotora no indicada")</p>
    </div>

    <div class="price-row">
        <p class="price">
            @if (Promotion.PriceFrom.HasValue)
            {
                <span>Desde</span>
            }
            @UiFormatting.Price(Promotion.PriceFrom)
        </p>
        <span class="confidence" title="Confianza de la fuente">
            <i style="--confidence: @Promotion.SourceConfidence.ToString("P0", System.Globalization.CultureInfo.InvariantCulture)"></i>
            @Promotion.SourceConfidence.ToString("P0")
        </span>
    </div>

    <dl class="feature-grid">
        <div>
            <dt>Casa</dt>
            <dd>@(Promotion.PropertyTypes.Count > 0 ? string.Join(", ", Promotion.PropertyTypes) : "No indicada")</dd>
        </div>
        <div>
            <dt>Dormitorios</dt>
            <dd>@UiFormatting.Range(Promotion.BedroomsMin, Promotion.BedroomsMax, "")</dd>
        </div>
        <div>
            <dt>Construidos</dt>
            <dd>@UiFormatting.Range(Promotion.BuiltAreaMinSqm, Promotion.BuiltAreaMaxSqm, "m²")</dd>
        </div>
        <div>
            <dt>Parcela</dt>
            <dd>@UiFormatting.Range(Promotion.PlotAreaMinSqm, Promotion.PlotAreaMaxSqm, "m²")</dd>
        </div>
    </dl>

    <div class="card-footer">
        <div class="card-meta">
            <span>@UiFormatting.Source(Promotion.SourceKind)</span>
            <span>Revisada @UiFormatting.Date(Promotion.LastSeenUtc)</span>
        </div>
        <div class="card-actions">
            <button class="card-open-button" type="button" @onclick="OpenAsync">
                Ver ficha <span aria-hidden="true">→</span>
            </button>
            <a class="source-link" href="@Promotion.CanonicalUrl" target="_blank" rel="noopener noreferrer">
                Fuente <span aria-hidden="true">↗</span>
            </a>
        </div>
    </div>
</article>

@code {
    [Parameter, EditorRequired]
    public Promotion Promotion { get; set; } = null!;

    [Parameter]
    public bool IsNew { get; set; }

    [Parameter]
    public bool IsChanged { get; set; }

    [Parameter]
    public bool IsHighlighted { get; set; }

    [Parameter]
    public EventCallback<string?> OnHighlight { get; set; }

    [Parameter]
    public EventCallback<Promotion> OnOpen { get; set; }

    private Task OpenAsync()
    {
        return OnOpen.InvokeAsync(Promotion);
    }

    private Task HighlightAsync()
    {
        return OnHighlight.InvokeAsync(Promotion.Id);
    }

    private Task ClearHighlightAsync()
    {
        return OnHighlight.InvokeAsync((string?)null);
    }
}
